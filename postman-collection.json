        {
          "id": "ec2463e9-7bd1-481d-a59a-9f94b9d1488e",
          "name": "login",
          "item": [
            {
              "id": "05c98847-a1a4-4154-b9f7-916ffcf8e4f8",
              "name": "login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const res = pm.response.json();",
                      "",
                      "if (res.success && res.data && res.data.token) {",
                      "    const token = res.data.token;",
                      "    const role = res.data.user?.role || 'user';",
                      "    pm.collectionVariables.set('USER_ACCESS_TOKEN', `Bearer ${token}`);",
                      "    pm.collectionVariables.set('USER_ROLE', role);",
                      "    console.log(`Token saved as USER_ACCESS_TOKEN for role: ${role}`);",
                      "} else {",
                      "    console.log('Login failed or no token in response');",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"email\": \"test@gmail.com\",\n    \"password\": \"12345678\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{BASE_API}}/auth/login",
                  "host": ["{{BASE_API}}"],
                  "path": ["auth", "login"]
                }
              }
            },
