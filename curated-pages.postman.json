  "item": [
    {
      "name": "Create Page (Draft)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{ADMIN_ACCESS_TOKEN}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"title\": \"Best Action Movies of 2026\",\n    \"description\": \"A curated list of the top action movies released in 2026.\",\n    \"bannerImage\": \"https://example.com/banner.jpg\",\n    \"seoTitle\": \"Best Action Movies 2026 | My Site\",\n    \"seoDescription\": \"Discover the top action movies of 2026 curated by our editors.\",\n    \"introContent\": \"<p>Welcome to our curated collection of the best action movies of 2026.</p>\",\n    \"faqContent\": \"[{\\\"question\\\":\\\"What is this list?\\\",\\\"answer\\\":\\\"A curated selection of top action movies.\\\"}]\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BASE_API}}/admin/pages",
          "host": ["{{BASE_API}}"],
          "path": ["admin", "pages"]
        }
      }
    },
