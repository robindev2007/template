{
  "name": "template",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:server": "bun --watch --env-file=.env src/server.ts",
    "dev:worker": "bun --watch --env-file=.env src/worker.ts",
    "dev": "bun run scripts/dev-runner.ts",
    "build:server": "bun build src/server.ts --outdir dist --target bun",
    "build:worker": "bun build src/worker.ts --outdir dist --target bun",
    "build": "bun run build:server && bun run build:worker",
    "start:server": "bun dist/server.js",
    "start:worker": "bun dist/worker.js",
    "start": "bun run scripts/start-runner.ts",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepare": "husky",
    "email": "email dev --dir ./src/services/email/templates --port 3001"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@react-email/ui": "6.6.6",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/figlet": "^1.7.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "ts-jest": "^29.4.11",
    "typescript-eslint": "^8.62.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@bull-board/api": "^8.1.0",
    "@bull-board/express": "^8.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/express": "^5.0.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.2",
    "chalk": "^5.6.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "figlet": "^1.11.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-email": "6.6.6",
    "react-icons": "^5.7.0",
    "zod": "^4.4.3"
  }
}
