{
  "name": "template",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:server": "bun --hot src/server.ts",
    "dev:worker": "bun --hot src/worker.ts",
    "dev": "concurrently --prefix \"{name}\" --names \",[worker] \" \"bun run dev:server\" \"bun run dev:worker\"",
    "build:server": "bun build src/server.ts --outdir dist --target bun",
    "build:worker": "bun build src/worker.ts --outdir dist --target bun",
    "build": "bun run build:server && bun run build:worker",
    "start:server": "bun dist/server.js",
    "start:worker": "bun dist/worker.js",
    "start": "concurrently --hide 0,1 --prefix \"{name}\" --names \" ,worker\" \"bun --env-file=.env.prod run start:server\" \"bun --env-file=.env.prod run start:worker\"",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "bullmq": {
      "ioredis": "$ioredis"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/bun": "latest",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "ts-jest": "^29.4.11",
    "typescript-eslint": "^8.62.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/express": "^5.0.6",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  }
}
